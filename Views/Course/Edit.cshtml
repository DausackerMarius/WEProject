@model WeProject.Models.Course

@{
    ViewData["Title"] = "Kurs bearbeiten";
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            &larr; Zurück zur Übersicht
        </a>
    </div>

    <h2 class="mb-4">Kurs bearbeiten: <span class="text-primary">@Model.Title</span></h2>

    <div class="card shadow-sm border-0 bg-light">
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Titel der Veranstaltung</label>
                            <input asp-for="Title" class="form-control" required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="LecturerName" class="form-label fw-bold">Name des Dozenten</label>
                            <input asp-for="LecturerName" class="form-control" required />
                            <span asp-validation-for="LecturerName" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-check mb-4 mt-3">
                            <input asp-for="IsMasterCourse" class="form-check-input" />
                            <label asp-for="IsMasterCourse" class="form-check-label">
                                Dies ist ein Master-Studiengang (M.Sc.)
                            </label>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success fw-bold px-4">Änderungen speichern</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Abbrechen</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>