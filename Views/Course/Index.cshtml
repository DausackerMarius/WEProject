@model IEnumerable<WeProject.Models.Course>
@{
    ViewData["Title"] = "Lehrveranstaltungen";
}

<div class="container mt-5">
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📚 Verwaltung der Lehrveranstaltungen</h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">Neue Veranstaltung anlegen</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" style="width: 30%;">Titel</th>
                            <th scope="col" style="width: 20%;">Dozent</th>
                            <th scope="col" style="width: 10%;">Typ</th>
                            <th scope="col" style="width: 10%;" class="text-center">Kapitel</th>
                            <th scope="col" style="width: 15%;" class="text-center">Prüfungen</th>
                            <th scope="col" style="width: 15%;" class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in Model)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <a href="/Chapter?courseId=@course.Id" class="text-decoration-none text-primary fs-5 d-block">
                                        @course.Title
                                    </a>
                                </td>
                                <td>@course.LecturerName</td>
                                <td>
                                    <span class="badge @(course.IsMasterCourse ? "bg-info text-dark" : "bg-secondary")">
                                        @(course.IsMasterCourse ? "Master" : "Bachelor")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border fs-6 shadow-sm">
                                        @course.Chapters.Count
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="/Exam?courseId=@course.Id" class="btn btn-outline-warning btn-sm position-relative text-dark fw-bold shadow-sm">
                                        Prüfungen
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark border border-light">
                                            @course.Exams.Count
                                        </span>
                                    </a>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center">
                                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary me-2">Bearbeiten</a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#deleteConfirmationModal"
                                                data-delete-url="@Url.Action("Delete", "Course", new { id = course.Id })"
                                                data-delete-main-text="Möchten Sie diese Lehrveranstaltung wirklich löschen?"
                                                data-delete-item-name="@course.Title"
                                                data-delete-item-line1="Dozent: @course.LecturerName"
                                                data-delete-item-line2="Studiengang: @(course.IsMasterCourse ? "Master" : "Bachelor")"
                                                data-delete-warning-text="Dieser Vorgang kann nicht rückgängig gemacht werden. Alle zugehörigen Kapitel, Fragen und Prüfungen werden ebenfalls gelöscht.">
                                            Löschen
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center p-4">
            <p class="mb-2">Es sind noch keine Lehrveranstaltungen im System hinterlegt.</p>
            <small class="text-muted">Klicke oben rechts auf <strong>"Neue Veranstaltung anlegen"</strong>, um zu starten!</small>
        </div>
    }
</div>

<partial name="_DeleteConfirmation" />

@section Scripts {
    }