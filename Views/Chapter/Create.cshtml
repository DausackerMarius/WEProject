            */

            pdfFileInput.addEventListener('change', async function() {
                if (!this.files.length) {
                    return;
                }

                const fileName = this.files[0].name;
                const genericNamePattern = /^(skript|script|vorlesung|lecture|kapitel|chapter|einfach-pdf|pdf)[\s_-]*\d*|guid/i;

                if (genericNamePattern.test(fileName)) {
                    setFeedback(fileNameFeedback, 'Generischer Dateiname erkannt. Frage KI nach einem besseren Namen...', 'primary');
                    
                    const formData = new FormData();
                    formData.append('pdfFile', this.files[0]);

                    try {
                        const response = await fetch('/Chapter/SuggestFileName', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await response.json();

                        if (response.ok && result.success && result.suggestedName) {
                            const userConfirmed = confirm(`Die KI schlägt vor, die Datei in "${result.suggestedName}.pdf" umzubenennen. Einverstanden?`);
                            if (userConfirmed) {
                                desiredFileNameInput.value = `${result.suggestedName}.pdf`;
                                setFeedback(fileNameFeedback, `Dateiname wird als "${result.suggestedName}.pdf" gespeichert.`, 'success');
                            } else {
                                desiredFileNameInput.value = '';
                                setFeedback(fileNameFeedback, 'Der ursprüngliche Dateiname wird beibehalten.', 'warning');
                            }
                        } else {
                            setFeedback(fileNameFeedback, result.message || 'Dateiname konnte nicht von der KI verbessert werden.', 'danger');
                        }
                    } catch (error) {
                        setFeedback(fileNameFeedback, 'Fehler bei der Kommunikation mit dem Server.', 'danger');
                    }
                } else {
                    fileNameFeedback.textContent = '';
                }
            });
        });
    </script>
}