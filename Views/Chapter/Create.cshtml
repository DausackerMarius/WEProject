@model WeProject.Models.Chapter

@{
    ViewData["Title"] = "Neues Kapitel";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm" style="border-color: #003366;">
                <div class="card-header text-white" style="background-color: #003366;">
                    <h3 class="mb-0">Neues Kapitel anlegen</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" enctype="multipart/form-data" id="createChapterForm">
                        <input type="hidden" asp-for="CourseId" value="@ViewBag.CourseId" />
                        <input type="hidden" name="desiredFileName" id="desiredFileName" />
                        <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Titel des Kapitels</label>
                            <div class="input-group">
                                <input asp-for="Title" id="chapterTitleInput" class="form-control" placeholder="z. B. Einführung in ASP.NET" required />
                                @* FIX: Temporär deaktiviert - Titel aus PDF auslesen (KI-Funktion) *@
                                @*
                                <button type="button" class="btn" style="background-color: #FFC107; color: #000;" id="btnSuggestTitle">
                                    ✨ Titel aus PDF auslesen
                                </button>
                                *@
                            </div>
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <div id="titleGenerationFeedback" class="form-text mt-2"></div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Kapitelnummer</label>
                            <input type="number" name="ChapterNumber" id="ChapterNumber" class="form-control" value="@ViewBag.NextChapterNumber" readonly />
                            <div class="form-text">Die Nummer wird automatisch vergeben.</div>
                        </div>
                        
                        <div class="mb-4">
                            <label for="pdfFileInput" class="form-label fw-bold">PDF-Dokument</label>
                            <input type="file" id="pdfFileInput" class="form-control" name="uploadedPdf" accept=".pdf" required />
                            <div class="form-text">Lade hier das Skript für das Kapitel hoch.</div>
                            <div id="fileNameFeedback" class="form-text mt-2"></div>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-action="Index" asp-route-courseId="@ViewBag.CourseId" class="btn btn-outline-secondary">Abbrechen</a>
                            <button type="submit" class="btn text-white" style="background-color: #003366;">Kapitel speichern</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const feedbackBox = document.getElementById('titleGenerationFeedback');
            const titleInput = document.getElementById('chapterTitleInput');
            const suggestButton = document.getElementById('btnSuggestTitle');
            const pdfFileInput = document.getElementById('pdfFileInput');
            const desiredFileNameInput = document.getElementById('desiredFileName');
            const fileNameFeedback = document.getElementById('fileNameFeedback');

            function setFeedback(element, message, type = 'danger') {
                element.textContent = message;
                // Klassen sicher verwalten, um bestehende Klassen nicht zu überschreiben
                element.classList.remove('text-danger', 'text-success', 'text-primary', 'text-warning');
                element.classList.add(`text-${type}`);
            }

            // FIX: Temporär deaktiviert - Titel aus PDF auslesen (KI-Funktion)
            /*
            suggestButton.addEventListener('click', async function() {
                const fileInput = document.createElement('input');
                fileInput.type = 'file';
