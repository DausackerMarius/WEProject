@*
    Dieses Partial View enthält den wiederverwendbaren Bootstrap-Modal-Dialog für Lösch-Bestätigungen.
    Es wird durch JavaScript mit den spezifischen Daten des zu löschenden Elements befüllt.
*@

<div class="modal fade" id="deleteConfirmationModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Löschvorgang bestätigen</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h3 class="mb-0" id="delete-modal-main-text">Möchten Sie dieses Element wirklich löschen?</h3>
                
                @* Dieser Bereich wird per JS befüllt *@
                <div id="delete-modal-details" class="mt-3">
                    <h4 class="card-title" id="delete-modal-item-name"></h4>
                    <p class="card-text" id="delete-modal-item-line1"></p>
                    <p class="card-text" id="delete-modal-item-line2"></p>
                </div>
                
                <div class="alert alert-danger mt-4" role="alert">
                    <strong>Achtung:</strong> <span id="delete-modal-warning-text">Dieser Vorgang kann nicht rückgängig gemacht werden.</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                
                @* Dieses Formular wird per JavaScript mit der korrekten Action-URL befüllt *@
                <form id="delete-confirmation-form" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Endgültig löschen</button>
                </form>
            </div>
        </div>
    </div>
</div>
