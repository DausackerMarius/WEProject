@model WeProject.Models.Question

@{
    ViewData["Title"] = "Frage bearbeiten";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0">Prüfungsfrage bearbeiten</h3>
                </div>
                <div class="card-body bg-light">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ChapterId" />

                        <div class="mb-4">
                            <label asp-for="Text" class="form-label fw-bold">Fragentext</label>
                            <textarea asp-for="Text" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Text" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 fw-bold text-secondary">Antwortoptionen bearbeiten</h5>

                        @{
                            var optionsList = Model.AnswerOptions.OrderBy(o => o.Id).ToList();
                        }

                        @for (int i = 0; i < optionsList.Count && i < 4; i++)
                        {
                            <input type="hidden" name="optionIds" value="@optionsList[i].Id" />
                            
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body bg-white rounded d-flex align-items-center gap-3">
                                    <div class="form-check m-0">
                                        <input class="form-check-input" type="radio" name="correctOptionIndex" value="@i" id="radioOption@i" @(i == ViewBag.CorrectOptionIndex ? "checked" : "") required />
                                        <label class="form-check-label fw-bold text-success" for="radioOption@i">Richtig</label>
                                    </div>
                                    <div class="flex-grow-1">
                                        <input type="text" name="options" value="@optionsList[i].Text" class="form-control" required />
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" asp-route-chapterId="@Model.ChapterId" class="btn btn-outline-secondary">Abbrechen</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold text-dark">Änderungen speichern</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}