@model WeProject.Models.Question

@{
    ViewData["Title"] = "Neue Frage anlegen";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Neue Prüfungsfrage manuell anlegen</h3>
                </div>
                <div class="card-body bg-light">
                    <form asp-action="Create">
                        <input type="hidden" asp-for="ChapterId" value="@ViewBag.ChapterId" />

                        <div class="mb-4">
                            <label asp-for="Text" class="form-label fw-bold">Fragentext</label>
                            <textarea asp-for="Text" class="form-control" rows="3" placeholder="Geben Sie hier die Prüfungsfrage ein..." required></textarea>
                            <span asp-validation-for="Text" class="text-danger"></span>
                        </div>

                        <h5 class="mb-3 fw-bold text-secondary">Antwortoptionen (Exakt 4 Optionen)</h5>
                        <p class="text-muted small">Tragen Sie die Texte ein und bestimmen Sie über das Radio-Control die einzig richtige Antwort.</p>

                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="card mb-3 border-0 shadow-sm">
                                <div class="card-body bg-white rounded d-flex align-items-center gap-3">
                                    <div class="form-check m-0">
                                        <input class="form-check-input" type="radio" name="correctOptionIndex" value="@i" id="radioOption@i" @(i == 0 ? "checked" : "") required />
                                        <label class="form-check-label fw-bold text-success" for="radioOption@i">Richtig</label>
                                    </div>
                                    <div class="flex-grow-1">
                                        <input type="text" name="options" class="form-control" placeholder="Antwortoption @(i + 1)" required />
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" asp-route-chapterId="@ViewBag.ChapterId" class="btn btn-outline-secondary">Abbrechen</a>
                            <button type="submit" class="btn btn-success px-4">Frage speichern</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}