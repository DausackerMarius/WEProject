@model WeProject.Models.Chapter

@{
    ViewData["Title"] = "Prüfungsfragen - " + Model.Title;
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary">
            &larr; Zurück zur Kapitelübersicht
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Prüfungsfragen: @Model.Title</h2>
        <div class="d-flex gap-2">
            <a asp-controller="Question" asp-action="Create" asp-route-chapterId="@Model.Id" class="btn btn-success fw-bold shadow-sm">
                Frage manuell anlegen
            </a>
            <button type="button" class="btn btn-warning fw-bold text-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#kiUploadModal">
                Neue Frage generieren
            </button>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
    }

    <div class="mt-4">
        @if (Model.Questions != null && Model.Questions.Any())
        {
            @foreach (var question in Model.Questions)
            {
                <div class="card shadow-sm mb-4 border-0 box-shadow">
                    <div class="card-header bg-secondary bg-opacity-10 fw-bold text-dark fs-5 py-3">
                        @question.Text
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @if (question.AnswerOptions != null)
                            {
                                @foreach (var option in question.AnswerOptions)
                                {
                                    <li class="list-group-item d-flex align-items-center gap-3 py-3 @(option.IsCorrect ? "bg-success bg-opacity-10" : "")">
                                        @if (option.IsCorrect)
                                        {
                                            <span class="badge bg-success px-3 py-2">Korrekt</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2">Falsch</span>
                                        }
                                        <span class="fs-6">@option.Text</span>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-end gap-2 py-2 border-top">
                        <a asp-controller="Question" asp-action="Edit" asp-route-id="@question.Id" class="btn btn-sm btn-outline-primary px-3 fw-bold">Bearbeiten</a>
                        <form asp-controller="Question" asp-action="Delete" asp-route-id="@question.Id" method="post" onsubmit="return confirm('Möchten Sie diese Frage wirklich löschen?');" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 fw-bold">Löschen</button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-secondary text-center py-5 shadow-sm border-0">
                <p class="mb-2 fs-5 text-muted">Bisher wurden keine Prüfungsfragen für dieses Kapitel angelegt.</p>
                <small class="text-muted">Nutze die Buttons oben, um manuell Fragen hinzuzufügen oder ein Vorlesungs-PDF per KI analysieren zu lassen!</small>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="kiUploadModal" tabindex="-1" aria-labelledby="kiUploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold" id="kiUploadModalLabel">✨ KI-Fragen für dieses Kapitel generieren</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Generator" asp-action="GenerateForChapter" method="post" enctype="multipart/form-data">
                <div class="modal-body py-4">
                    <input type="hidden" name="chapterId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label for="pdfFile" class="form-label fw-bold">Wähle das Vorlesungs-PDF aus:</label>
                        <input type="file" name="pdfFile" id="pdfFile" class="form-control form-control-lg" accept=".pdf" required />
                    </div>
                    <div class="alert alert-info border-0 mb-0 small text-muted">
                        <strong>Ablauf:</strong> Das Skript lädt das PDF in den lokalen Azurite-Emulator hoch, liest den Text mittels <em>PdfPig</em> aus und schickt diesen an OpenAI. Die generierten Multiple-Choice-Fragen werden direkt in deine SQLite-Datenbank geschrieben.
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-warning fw-bold text-dark">Generieren starten</button>
                </div>
            </form>
        </div>
    </div>
</div>