@model WeProject.Models.Course

@{
    ViewData["Title"] = "Prüfungen - " + Model.Title;
}

<div class="container mt-4">
    <div class="mb-4 d-flex gap-2">
        <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Zurück zur Kursliste
        </a>
        <a asp-controller="Chapter" asp-action="Index" asp-route-courseId="@Model.Id" class="btn btn-outline-primary">
            📖 Zu den Kapiteln & Fragen
        </a>
    </div>

    <h2 class="mb-4">Prüfungsverwaltung: @Model.Title</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="row mb-5 justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3 text-primary">Neue Prüfung aus dem Fragenpool erstellen</h5>
                    <p class="text-muted small mb-4">Das System stellt automatisch eine zufällige Prüfung aus allen KI-generierten Fragen der verschiedenen Kapitel zusammen.</p>
                    <form asp-action="Generate" method="post">
                        <input type="hidden" name="courseId" value="@Model.Id" />
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label for="examDate" class="form-label fw-bold">Datum</label>
                                <input type="date" id="examDate" name="examDate" class="form-control" value="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-3">
                                <label for="examTime" class="form-label fw-bold">Uhrzeit</label>
                                <input type="time" id="examTime" name="examTime" class="form-control" value="10:00" required />
                            </div>
                            <div class="col-md-3">
                                <label for="questionCount" class="form-label fw-bold">Anzahl Fragen</label>
                                <input type="number" id="questionCount" name="questionCount" class="form-control" min="1" value="10" required />
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-success fw-bold shadow-sm w-100">Prüfung generieren</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <h3>Gespeicherte Prüfungen</h3>
    <div class="row mt-3">
        @if (Model.Exams != null && Model.Exams.Any())
        {
            @foreach (var exam in Model.Exams.OrderByDescending(e => e.ExamDate))
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-primary h-100">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title text-primary">Prüfung vom @exam.ExamDate.ToString("dd.MM.yyyy")</h5>
                                <p class="card-text text-muted">@exam.ExamDate.ToString("HH:mm") Uhr</p>
                                <div class="display-6 fw-bold mb-3">
                                    @(exam.Questions != null ? exam.Questions.Count : 0) <span class="fs-5 fw-normal text-muted">Fragen</span>
                                </div>
                            </div>
                            <div class="d-grid gap-2">
                                <a asp-action="Print" asp-route-id="@exam.Id" target="_blank" class="btn btn-outline-primary fw-bold">Druckansicht öffnen</a>
                                
                                <button type="button" class="btn btn-sm btn-link text-danger text-decoration-none" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#deleteConfirmationModal"
                                        data-delete-url="@Url.Action("Delete", "Exam", new { id = exam.Id })"
                                        data-delete-main-text="Möchten Sie diese Prüfung wirklich löschen?"
                                        data-delete-item-name="Prüfung vom @exam.ExamDate.ToString("dd.MM.yyyy")"
                                        data-delete-item-line1="@((exam.Questions != null ? exam.Questions.Count : 0) + " Fragen")"
                                        data-delete-warning-text="Dieser Vorgang kann nicht rückgängig gemacht werden.">
                                    Prüfung verwerfen
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-secondary text-center p-4">Bisher wurden keine Prüfungen für diese Veranstaltung generiert.</div>
            </div>
        }
    </div>
</div>

<partial name="_DeleteConfirmation" />