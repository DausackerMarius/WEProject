@model WeProject.Models.Course

@{
    ViewData["Title"] = "Prüfungen - " + Model.Title;
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">
            &larr; Zurück zur Kursliste
        </a>
    </div>

    <h2 class="mb-4">Prüfungsverwaltung: @Model.Title</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm border-0 mb-5 bg-light">
        <div class="card-body">
            <h5 class="card-title">Neue Prüfung erstellen</h5>
            <form asp-action="Generate" method="post" class="d-flex align-items-center gap-3 mt-3">
                <input type="hidden" name="courseId" value="@Model.Id" />
                <label for="questionCount" class="fw-bold mb-0">Anzahl Fragen:</label>
                <input type="number" id="questionCount" name="questionCount" class="form-control w-25" min="1" value="10" required />
                <button type="submit" class="btn btn-warning fw-bold shadow-sm">Prüfung generieren</button>
            </form>
        </div>
    </div>

    <h3>Gespeicherte Prüfungen</h3>
    <div class="row mt-3">
        @if (Model.Exams != null && Model.Exams.Any())
        {
            @foreach (var exam in Model.Exams.OrderByDescending(e => e.ExamDate))
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-primary h-100">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title text-primary">Prüfung vom @exam.ExamDate.ToString("dd.MM.yyyy")</h5>
                                <p class="card-text text-muted">@exam.ExamDate.ToString("HH:mm") Uhr</p>
                                <div class="display-6 fw-bold mb-3">
                                    @(exam.Questions != null ? exam.Questions.Count : 0) <span class="fs-5 fw-normal text-muted">Fragen</span>
                                </div>
                            </div>
                            <div class="d-grid gap-2">
                                <a asp-action="Print" asp-route-id="@exam.Id" target="_blank" class="btn btn-outline-primary fw-bold">Druckansicht öffnen</a>
                                
                                <form asp-action="Delete" asp-route-id="@exam.Id" method="post" onsubmit="return confirm('Möchten Sie diese generierte Prüfung wirklich löschen?');">
                                    <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none">Prüfung verwerfen</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-secondary">Bisher wurden keine Prüfungen für diese Veranstaltung generiert.</div>
            </div>
        }
    </div>
</div>